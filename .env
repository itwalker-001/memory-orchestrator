# Database
POSTGRES_DB=memory_orchestrator
POSTGRES_USER=postgres
MO_DB_PASSWORD=mo_secret
MO_DB_PORT=15432
MO_PGDATA=./data/postgres
MO_DB_DSN=postgresql+asyncpg://postgres:mo_secret@memory-orchestrator-db:5432/memory_orchestrator

# Server
MO_HTTP_HOST=0.0.0.0
MO_HTTP_PORT=8765

# Embedding / reranker
MO_EMBED_MODEL=/app/memory_orchestrator_server/models/BAAI/bge-m3
MO_EMBED_DIM=1024
MO_RERANK_MODEL=/app/memory_orchestrator_server/models/BAAI/bge-reranker-v2-m3

# Logging
MO_LOG_LEVEL=INFO

# Extraction LLM
MO_EXTRACTION_BASE_URL=https://timicc.com
MO_EXTRACTION_MODEL=gpt-4o-mini
MO_EXTRACTION_API_KEY=sk-7e7dca5adf97760b570fd40b1f1a73f52d80ba128f4a8bdcb4be4462c1d16075

# Build
MO_DB_IMAGE=memory-orchestrator-db:latest
MO_BASE_IMAGE=memory-orchestrator-server-base:latest
TORCH_INDEX=cpu
SOCKS5_PROXY=socks5h://172.16.10.30:1080
