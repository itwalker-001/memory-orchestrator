{
  "client": "claude",
  "default_home": "~/.claude",
  "config": {
    "format": "json",
    "path": "settings.json",
    "managed_paths": [
      ["hooks", "UserPromptSubmit"],
      ["hooks", "Stop"],
      ["mcpServers", "memory-orchestrator"]
    ],
    "patches": [
      {
        "path": ["hooks", "UserPromptSubmit"],
        "value": [
          {
            "hooks": [
              {
                "type": "command",
                "command": "uv run --no-sync --project {project_dir}/memory_orchestrator_mcp python {project_dir}/memory_orchestrator_mcp/hooks/user_prompt_submit.py --client claude --base-url {base_url}"
              }
            ]
          }
        ]
      },
      {
        "path": ["hooks", "Stop"],
        "value": [
          {
            "hooks": [
              {
                "type": "command",
                "command": "uv run --no-sync --project {project_dir}/memory_orchestrator_mcp python {project_dir}/memory_orchestrator_mcp/hooks/stop.py --client claude --base-url {base_url}"
              }
            ]
          }
        ]
      },
      {
        "path": ["mcpServers", "memory-orchestrator"],
        "value": {
          "command": "uv",
          "args": ["run", "--no-sync", "--project", "{project_dir}/memory_orchestrator_mcp", "mo-mcp", "serve-mcp", "--client", "claude"],
          "env": {"MO_CLIENT": "claude", "MO_HTTP_BASE_URL": "{base_url}"}
        }
      }
    ]
  },
  "mcp_registration": {
    "command": ["claude", "mcp", "add", "--scope", "{scope}", "memory-orchestrator", "--", "uv", "run", "--no-sync", "--project", "{project_dir}/memory_orchestrator_mcp", "mo-mcp", "serve-mcp", "--client", "claude"]
  },
  "instructions": {
    "source": "memory_orchestrator_mcp/skills/memory-orchestrator/SKILL.md",
    "destination": "skills/memory-orchestrator/SKILL.md"
  }
}
