{
  "client": "codex",
  "home_env": "CODEX_HOME",
  "default_home": "~/.codex",
  "config": {
    "format": "toml",
    "path": "config.toml",
    "managed_paths": [["mcp_servers", "memory-orchestrator"]],
    "patches": [
      {
        "path": ["features", "hooks"],
        "value": true
      },
      {
        "path": ["mcp_servers", "memory-orchestrator"],
        "value": {
          "command": "uv",
          "args": ["run", "--no-sync", "--project", "{project_dir}/memory_orchestrator_mcp", "mo-mcp", "serve-mcp", "--client", "codex"],
          "env": {"MO_CLIENT": "codex", "MO_HTTP_BASE_URL": "{base_url}"}
        }
      }
    ]
  },
  "hooks": {
    "format": "json",
    "path": "hooks.json",
    "events": {
      "UserPromptSubmit": [
        {
          "hooks": [
            {
              "type": "command",
              "command": "uv run --no-sync --project {project_dir}/memory_orchestrator_mcp python {project_dir}/memory_orchestrator_mcp/hooks/user_prompt_submit.py --client codex"
            }
          ]
        }
      ],
      "Stop": [
        {
          "hooks": [
            {
              "type": "command",
              "command": "uv run --no-sync --project {project_dir}/memory_orchestrator_mcp python {project_dir}/memory_orchestrator_mcp/hooks/stop.py --client codex"
            }
          ]
        }
      ]
    }
  },
  "instructions": {
    "source": "memory_orchestrator_mcp/agents/memory-orchestrator.AGENTS.md",
    "destination": "AGENTS.md"
  }
}
