MO_DB_DSN=postgresql+asyncpg://postgres:1234@localhost:5433/memory_orchestrator
MO_HTTP_PORT=8765
MO_EMBED_MODEL=BAAI/bge-small-zh-v1.5
MO_EMBED_DIM=512
MO_HAIKU_MODEL=claude-haiku-4-5
MO_LOG_LEVEL=INFO
# 以下沿用 ~/.claude/settings.json 同名值
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=

# Test DB — integration tests run against this; create manually before running pytest:
#   CREATE DATABASE memory_orchestrator_test;
#   \c memory_orchestrator_test
#   CREATE EXTENSION vector; CREATE EXTENSION pgcrypto;
MO_TEST_DB_DSN=postgresql+asyncpg://postgres:1234@localhost:5433/memory_orchestrator_test

# ── Docker deployment ──────────────────────────────────────────────────────────
# Copy to .env and fill in values, then: docker compose up -d
# MO_DB_PASSWORD=mo_secret
# MO_EXTRACTION_BASE_URL=https://api.openai.com/v1
# MO_EXTRACTION_MODEL=gpt-4o-mini
# MO_EXTRACTION_API_KEY=sk-...
